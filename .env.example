# =============================================
# 画宗制片中枢 — 环境变量配置
# 复制此文件为 .env 并填写实际值
# cp .env.example .env && vim .env
# =============================================

# ----- PostgreSQL 数据库 -----
# Docker Compose 用于初始化 PostgreSQL 容器
POSTGRES_USER=huazong
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_DB=huazong_studio

# 注意: DB_HOST/DB_USERNAME/DB_PASSWORD/DB_DATABASE 由 docker-compose.yml
# 自动从上面的 POSTGRES_* 变量映射，无需重复配置

# ----- Redis 缓存 -----
KV_HOST=redis
KV_PORT=6379
# KV_PASSWORD=              # 如需 Redis 密码认证，取消注释

# ----- Meilisearch 全文搜索（2C2G 已禁用，留空即可）-----
# 如需启用：部署 MeiliSearch 容器并填写以下配置
INDEXER_HOST=
INDEXER_PORT=
INDEXER_KEY=

# ----- 事件流（zou events 服务）-----
EVENT_STREAM_HOST=events
EVENT_STREAM_PORT=5001

# ----- Flask 应用安全 -----
# 至少 32 个字符的随机字符串，可用: openssl rand -hex 32
SECRET_KEY=changeme_flask_secret_key_at_least_32_chars
JWT_SECRET_KEY=changeme_jwt_secret_key_at_least_32_chars

# ----- 文件存储路径（容器内路径）-----
PREVIEW_FOLDER=/opt/zou/previews
TMP_DIR=/opt/zou/tmp

# ----- 邮件（可选，取消注释并填写）-----
# MAIL_SERVER=smtp.qq.com
# MAIL_PORT=465
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=noreply@huazong.com

# ----- Gunicorn 工作进程（2C2G 推荐 2）-----
GUNICORN_WORKERS=2
GUNICORN_LOG_LEVEL=info

# ----- Nginx 域名 -----
SERVER_NAME=studio.huazong.com

# ----- 腾讯云 COS 对象存储 -----
# 设置 FS_BACKEND=cos 启用 COS 存储（默认 local）
FS_BACKEND=local
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_REGION=ap-beijing
COS_BUCKET_PICTURES=huazong-pictures-1250000000
COS_BUCKET_MOVIES=huazong-movies-1250000000
COS_BUCKET_FILES=huazong-files-1250000000

# COS CDN 加速（可选）
COS_CDN_DOMAIN=
COS_CDN_ENABLED=false

# COS 预签名 URL 有效期（秒）
COS_PRESIGN_EXPIRED=3600

# COS 数据万象（图片处理）
COS_CI_ENABLED=false
COS_CI_THUMBNAIL_STYLE=imageView2/1/w/200/h/200
